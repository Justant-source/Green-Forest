# ===== Production 환경 변수 =====
# 서버에서 .env.prod로 복사 후 값 채우기 (git에 커밋하지 말 것)

# DB
DB_PASSWORD=your_prod_db_password

# JWT (prod용 별도 시크릿 사용 권장)
JWT_SECRET=your_prod_jwt_secret_key_must_be_at_least_256_bits_long

# Admin
ADMIN_PASSWORD=your_prod_admin_password

# CORS (실제 서비스 도메인 — Cloudflare Tunnel 경유)
CORS_ORIGINS=https://green-office.uk,https://www.green-office.uk

# Frontend API 주소 (브라우저가 접속하는 실제 주소)
# 주의: NEXT_PUBLIC_*는 빌드 타임에 JS 번들에 주입됨 → 값 변경 시 frontend 재빌드 필수
NEXT_PUBLIC_API_BASE_URL=https://green-office.uk/api
NEXT_PUBLIC_IMAGE_BASE_URL=https://green-office.uk
