# ===== Local/Dev 환경 변수 =====
# .env.local로 복사 후 값 채우기 (git에 커밋하지 말 것)

# DB
DB_PASSWORD=your_dev_db_password

# JWT
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long_for_hs256

# Admin
ADMIN_PASSWORD=your_admin_password

# CORS (브라우저 접속 주소 — localhost + Cloudflare Tunnel dev 도메인)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://dev.green-office.uk

# Frontend API 주소 (브라우저가 접속하는 주소)
# 주의: NEXT_PUBLIC_*는 빌드 타임에 JS 번들에 주입됨 → 값 변경 시 frontend 재빌드 필수
NEXT_PUBLIC_API_BASE_URL=https://dev.green-office.uk/api
NEXT_PUBLIC_IMAGE_BASE_URL=https://dev.green-office.uk
