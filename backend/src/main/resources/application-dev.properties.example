# Dev 환경 설정 — application-dev.properties로 복사 후 값 채우기
# 직접 실행 시: 아래 값을 직접 채우거나 환경변수로 주입
# Docker 실행 시: docker-compose.dev.yml의 environment 또는 .env.dev 사용

spring.datasource.url=jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3308}/${DB_NAME:vgc_db_dev}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

server.port=9091

jwt.secret=${JWT_SECRET}

# Admin initial password
app.admin.password=${ADMIN_PASSWORD}

# CORS allowed origins (comma-separated)
app.cors.allowed-origins=${CORS_ORIGINS:http://localhost:3000,http://localhost:8080}

# Upload paths
file.upload-dir=${UPLOAD_PATH:/app/uploads}
app.upload.path=${UPLOAD_PATH:/app/uploads}/

# Notify polling token (사내 우분투 폴러용 — 환경변수로 주입)
app.notify.token=${NOTIFY_API_TOKEN:dev-local-token-please-change}
